    {
      "name": "order_status_analysis",
      "displayName": "Order Status Analysis",
      "queryLines": [
        "SELECT\n",
        "  order_status,\n",
        "  COUNT(DISTINCT order_id) as total_orders,\n",
        "  SUM(revenue) as total_revenue,\n",
        "  SUM(quantity) as total_units\n",
        "FROM\n",
        "  dev.gold.fact_sales\n",
        "GROUP BY\n",
        "  order_status"
      ],
      "catalog": "dev",
      "schema": "gold"
    },
    {
      "name": "customer_by_state",
      "displayName": "Customers by State",
      "queryLines": [
        "SELECT\n",
        "  state,\n",
        "  COUNT(DISTINCT customer_id) as total_customers,\n",
        "  COUNT(DISTINCT order_id) as total_orders\n",
        "FROM\n",
        "  dev.gold.fact_sales\n",
        "GROUP BY\n",
        "  state\n",
        "ORDER BY\n",
        "  total_customers DESC"
      ],
      "catalog": "dev",
      "schema": "gold"
    },
    {
      "name": "day_of_week_performance",
      "displayName": "Day of Week Performance",
      "queryLines": [
        "SELECT\n",
        "  CASE day_of_week\n",
        "    WHEN 1 THEN 'Sunday'\n",
        "    WHEN 2 THEN 'Monday'\n",
        "    WHEN 3 THEN 'Tuesday'\n",
        "    WHEN 4 THEN 'Wednesday'\n",
        "    WHEN 5 THEN 'Thursday'\n",
        "    WHEN 6 THEN 'Friday'\n",
        "    WHEN 7 THEN 'Saturday'\n",
        "  END as day_name,\n",
        "  day_of_week,\n",
        "  SUM(revenue) as total_revenue,\n",
        "  COUNT(DISTINCT order_id) as total_orders\n",
        "FROM\n",
        "  dev.gold.fact_sales\n",
        "GROUP BY\n",
        "  day_of_week\n",
        "ORDER BY\n",
        "  day_of_week"
      ],
      "catalog": "dev",
      "schema": "gold"
    }
  ],
